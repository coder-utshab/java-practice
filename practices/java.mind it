public class Main {
    public static void main(String[] args) {

        int x = 10;

        System.out.println(x);

        x = x + 5;

        System.out.println(x);

        x = x * 2;

        System.out.println(x);
    }
}








public class Main {
    public static void main(String[] args) {

        int marks = 35;

        if (marks >= 80) {
            System.out.println("A+");
        } else if (marks >= 60) {
            System.out.println("A");
        } else if (marks >= 40) {
            System.out.println("Pass");
        } else {
            System.out.println("Fail");
        }

        System.out.println("Result Published");
    }
}